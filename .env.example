VITE_TMAP_APP_KEY=your_tmap_app_key_here

# tmap_web_be (clusters, auth, Gemini proxy). Example: http://127.0.0.1:3001
# VITE_API_BASE_URL=http://127.0.0.1:3001
#
# Gemini: never put the API key in this frontend .env. Set GEMINI_API_KEY in
# tmap_web_be’s .env (or deployment secrets) and restart the Node server so it
# reads the variable (503 "GEMINI_API_KEY is not configured" means the backend
# process still has no key).

# Google Identity Services — same OAuth 2.0 Web client ID as backend GOOGLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Optional: when backend DEMO_SEED_SECRET is set, paste the same value here and it is sent as X-Demo-Seed-Secret from the AI demo UI (see below).
# VITE_DEMO_SEED_SECRET=
# AI summary demo: http://localhost:5173/#/demo/baby-ai — or click "AI 데모" (toolbar, API mode only).
